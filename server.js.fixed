// Routes for Expense Items - بنود المصروفات
app.get("/api/expense_items", (req, res) => getAll("expense_items", res));
app.get("/api/expense_items/:id", (req, res) =>
  getById("expense_items", req.params.id, res),
);
app.post("/api/expense_items", async (req, res) => {
  const client = await pool.connect();
  try {
    await client.query("BEGIN");

    // تنقية البيانات بناءً على القائمة المسموحة أولاً
    const rawData = filterData("expense_items", req.body);
    const sanitizedData = { ...rawData };

    // تصحيح أنواع البيانات الخاصة ببند المصروفات
    if (sanitizedData.is_mandatory !== undefined) {
      sanitizedData.is_mandatory =
        String(sanitizedData.is_mandatory).toLowerCase() === "true" ||
        sanitizedData.is_mandatory === true;
    }
    if (sanitizedData.is_service !== undefined) {
      sanitizedData.is_service =
        String(sanitizedData.is_service).toLowerCase() === "true" ||
        sanitizedData.is_service === true;
    }
    if (sanitizedData.amount !== undefined)
      sanitizedData.amount = Number(sanitizedData.amount);

    // 1. إنشاء بند المصروفات الجديد
    const keys = Object.keys(sanitizedData).join(", ");
    const placeholders = Object.keys(sanitizedData)
      .map((_, i) => `$${i + 1}`)
      .join(", ");
    const query = `INSERT INTO expense_items (${keys}) VALUES (${placeholders}) RETURNING *`;
    const result = await client.query(query, Object.values(sanitizedData));
    const newItem = result.rows[0];

    // 2. إذا كان إلزامياً، يتم إضافته فوراً لجميع الطلاب الحاليين المطابقين للقسم والفرقة
    if (newItem.is_mandatory) {
      await client.query(
        `
        INSERT INTO student_fees (student_id, expense_item_id, amount_due, status)
        SELECT id, $1, $2, 'pending'
        FROM students
        WHERE ($3::INTEGER IS NULL OR department_id = $3::INTEGER)
        AND ($4::VARCHAR IS NULL OR $4::VARCHAR = '' OR $4::VARCHAR = 'كل الفرق' OR class_year = $4::VARCHAR)
      `,
        [newItem.id, newItem.amount, newItem.department_id, newItem.class_year],
      );
    }
    await client.query("COMMIT");
    res.status(201).json(newItem);
  } catch (err) {
    console.error("Error in POST /api/expense_items transaction:", err.message);
    await client.query("ROLLBACK");
    res.status(500).json({ error: err.message });
  } finally {
    client.release();
  }
});
app.put("/api/expense_items/:id", (req, res) =>
  update("expense_items", req.params.id, req.body, res),
);
app.delete("/api/expense_items/:id", (req, res) =>
  remove("expense_items", req.params.id, res),
);

// Routes for Student Fees - مصروفات الطلاب
app.get("/api/student-fees", (req, res) =>
  getAll(
    "student_fees",
    res,
    "sf LEFT JOIN expense_items ei ON sf.expense_item_id = ei.id",
  ),
);

app.get("/api/student-fees/:studentId", async (req, res) => {
  try {
    const query = `
      SELECT sf.id, sf.student_id, sf.expense_item_id, sf.is_selected, sf.amount_due, sf.amount_paid, 
             (sf.amount_due - sf.amount_paid) as remaining_balance, sf.status, 
             COALESCE(ei.name, 'بند غير معروف') as item_name 
      FROM student_fees sf 
      LEFT JOIN expense_items ei ON sf.expense_item_id = ei.id 
      WHERE sf.student_id = $1
    `;
    const result = await pool.query(query, [req.params.studentId]);
    res.json(result.rows);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.post("/api/student-fees/pay", async (req, res) => {
  const { feeId, amount } = req.body;
  const client = await pool.connect();
  try {
    await client.query("BEGIN");
    const result = await client.query(
      "UPDATE student_fees SET amount_paid = amount_paid + $1, status = CASE WHEN (amount_due - (amount_paid + $1)) <= 0 THEN 'paid' ELSE 'pending' END, paid_date = CURRENT_DATE WHERE id = $2 RETURNING *",
      [amount, feeId],
    );
    if (result.rows.length === 0) {
      throw new Error("Fee record not found");
    }

    const fee = result.rows[0];
    const studentRes = await client.query(
      "SELECT branch_id FROM students WHERE id = $1",
      [fee.student_id],
    );
    let branchId = studentRes.rows[0]?.branch_id;

    // If student doesn't have branch_id, get it from department
    if (!branchId && fee.student_id) {
      const deptRes = await client.query(
        "SELECT d.branch_id FROM students s JOIN departments d ON s.department_id = d.id WHERE s.id = $1",
        [fee.student_id],
      );
      branchId = deptRes.rows[0]?.branch_id;
    }
    let updatedFinance = null;

    if (branchId) {
      const today = new Date().toISOString().split("T")[0];
      const financeRes = await client.query(
        "SELECT * FROM finances WHERE branch_id = $1 AND date = $2 FOR UPDATE",
        [branchId, today],
      );

      if (financeRes.rows.length > 0) {
        const existing = financeRes.rows[0];
        const newRevenue = Number(existing.revenue) + Number(amount);
        const newCashBalance = Number(existing.cash_balance) + Number(amount);
        const updateFinance = await client.query(
          "UPDATE finances SET revenue = $1, cash_balance = $2 WHERE id = $3 RETURNING *",
          [newRevenue, newCashBalance, existing.id],
        );
        updatedFinance = updateFinance.rows[0];
      } else {
        const insertFinance = await client.query(
          "INSERT INTO finances (branch_id, date, revenue, expenses, cash_balance, notes) VALUES ($1, $2, $3, 0, $3, $4) RETURNING *",
          [branchId, today, amount, "تحصيل رسوم الطلاب"],
        );
        updatedFinance = insertFinance.rows[0];
      }
    }

    await client.query("COMMIT");
    res.json({ fee, finance: updatedFinance });
  } catch (err) {
    await client.query("ROLLBACK");
    res.status(500).json({ error: err.message });
  } finally {
    client.release();
  }
});

