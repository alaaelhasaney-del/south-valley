const express = require("express");
const { Pool } = require("pg");
const bcrypt = require("bcrypt");
const jwt = require("jsonwebtoken");
require("dotenv").config();

const app = express();
const port = process.env.PORT || 3000;
const JWT_SECRET = process.env.JWT_SECRET || "fallback-secret-key";

// تحديد الحقول المسموح بها لكل جدول (Whitelist)
const TABLE_SCHEMAS = {
  branches: ["name", "location", "phone", "manager"],
  users: ["name", "email", "password_hash", "role", "branch_id"],
  students: [
    "tenant_id",
    "name",
    "email",
    "phone",
    "guardian_phone",
    "governorate",
    "city",
    "full_address",
    "national_id",
    "qualification",
    "department_id",
    "branch_id",
    "class_year",
    "photo_data",
  ],
  departments: ["name", "description", "branch_id"],
  courses: ["name", "description", "price", "department_id"],
  finances: [
    "branch_id",
    "date",
    "revenue",
    "expenses",
    "cash_balance",
    "notes",
  ],
  expense_items: [
    "name",
    "amount",
    "department_id",
    "branch_id",
    "class_year",
    "is_mandatory",
    "is_service",
    "description",
  ],
  role_permissions: [
    "role",
    "resource",
    "can_read",
    "can_create",
    "can_update",
    "can_delete",
    "branch_access",
  ],
  student_fees: [
    "student_id",
    "expense_item_id",
    "amount_due",
    "amount_paid",
    "status",
    "is_selected",
    "paid_date",
  ],
  student_grades: ["student_id", "course_id", "grade", "notes"],
  student_attendance: ["student_id", "course_id", "date", "status", "notes"],
};

// Middleware
app.use(express.json());
app.use(require("cors")({
  origin: ["http://localhost:5173", "http://localhost:3000"],
  credentials: true
}));
app.use(express.json({ limit: '10mb' }));
app.use(express.urlencoded({ extended: true, limit: '10mb' }));
app.use(require("helmet")());

// Postgres Pool (Supabase compatible)
const pool = new Pool({
  connectionString: process.env.DATABASE_URL,
  ssl:
    process.env.NODE_ENV === "production"
      ? { rejectUnauthorized: false }
      : false,
});

// JWT Authentication Middleware
const authenticateToken = async (req, res, next) => {
  const authHeader = req.headers["authorization"];
  const token = authHeader && authHeader.split(" ")[1];

  if (!token) {
    return res.status(401).json({ error: "Access token required" });
  }

  try {
    const decoded = jwt.verify(token, JWT_SECRET);
    const userResult = await pool.query("SELECT * FROM users WHERE id = $1", [
      decoded.id,
    ]);
    if (userResult.rows.length === 0) {
      return res.status(403).json({ error: "Invalid token" });
    }
    req.user = userResult.rows[0];
    next();
  } catch (err) {
    res.status(403).json({ error: "Invalid token" });
  }
};

// Branch Restriction Middleware (except for admins)
const restrictToBranch = (tables) => {
  return async (req, res, next) => {
    if (!req.user) return res.status(401).json({ error: "Unauthorized" });

    // Super admin has full access
    if (req.user.role === "admin") return next();

    const table = Object.keys(req.query).length
      ? req.query.table || req.params.table
      : req.path.split("/")[2];
    if (!tables.includes(table)) return next();

    // Add branch filter to query
    req.branchFilter = `branch_id = ${req.user.branch_id}`;
    next();
  };
};

// Test DB connection
pool.on("connect", () => console.log("Connected to DB"));
pool.on("error", (err) => console.error("DB connection error:", err));

// Generic CRUD functions
async function getAll(table, res, joins = "") {
  try {
    const query = `SELECT * FROM ${table} ${joins}`;
    const result = await pool.query(query);
    res.json(result.rows);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
}

async function getById(table, id, res, idCol = "id") {
  try {
    const query = `SELECT * FROM ${table} WHERE ${idCol} = $1`;
    const result = await pool.query(query, [id]);
    if (result.rows.length === 0)
      return res.status(404).json({ error: "Not found" });
    res.json(result.rows[0]);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
}

// دالة مساعدة لتنقية البيانات بناءً على القائمة المسموحة
function filterData(table, data) {
  const allowedFields = TABLE_SCHEMAS[table];
  if (!allowedFields) return data; // إذا لم يوجد تعريف، نمرر البيانات كما هي (أو يمكن منعها)

  const sanitizedData = {};
  allowedFields.forEach((key) => {
    if (data[key] !== undefined) {
      // تحويل النصوص الفارغة إلى null لضمان سلامة قاعدة البيانات
      sanitizedData[key] = data[key] === "" ? null : data[key];
    }
  });
  return sanitizedData;
}

async function create(table, data, res) {
  try {
    let sanitizedData = filterData(table, data);
    
    // Auto-set tenant_id for single-tenant mode (default tenant 1)
    if (table === 'students' && !sanitizedData.tenant_id) {
      sanitizedData.tenant_id = 1;
      console.log('Auto-set tenant_id=1 for new student');
    }
    
    const keys = Object.keys(sanitizedData).join(", ");
    const placeholders = Object.keys(sanitizedData)
      .map((_, i) => `$${i + 1}`)
      .join(", ");
    const result = await pool.query(
      `INSERT INTO ${table} (${keys}) VALUES (${placeholders}) RETURNING *`,
      Object.values(sanitizedData),
    );
    res.status(201).json(result.rows[0]);
  } catch (err) {
    console.error(`Error creating in ${table}:`, err.message);
    res.status(500).json({ error: err.message });
  }
}

async function update(table, id, data, res, idCol = "id") {
  try {
    let sanitizedData = filterData(table, data);
    
    // Preserve existing tenant_id, auto-set if missing for students
    if (table === 'students' && !sanitizedData.tenant_id) {
      sanitizedData.tenant_id = 1;
      console.log('Auto-set tenant_id=1 for student update');
    }
    
    const setClause = Object.keys(sanitizedData)
      .map((key, i) => `${key} = $${i + 1}`)
      .join(", ");
    const query = `UPDATE ${table} SET ${setClause}, updated_at = CURRENT_TIMESTAMP WHERE ${idCol} = $${Object.keys(sanitizedData).length + 1} RETURNING *`;
    const values = [...Object.values(sanitizedData), id];
    const result = await pool.query(query, values);
    if (result.rows.length === 0)
      return res.status(404).json({ error: "Not found" });
    res.json(result.rows[0]);
  } catch (err) {
    console.error(`Error updating ${table}:`, err.message);
    res.status(500).json({ error: err.message });
  }
}

async function remove(table, id, res, idCol = "id") {
  try {
    const query = `DELETE FROM ${table} WHERE ${idCol} = $1 RETURNING *`;
    const result = await pool.query(query, [id]);
    if (result.rows.length === 0)
      return res.status(404).json({ error: "Not found" });
    res.json({ message: "Deleted" });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
}

// Routes for Branches
app.get("/api/branches", (req, res) => getAll("branches", res));
app.get("/api/branches/:id", (req, res) =>
  getById("branches", req.params.id, res),
);
app.post("/api/branches", (req, res) => create("branches", req.body, res));
app.put("/api/branches/:id", (req, res) =>
  update("branches", req.params.id, req.body, res),
);
app.delete("/api/branches/:id", (req, res) =>
  remove("branches", req.params.id, res),
);

// Routes for Users
app.get("/api/users", (req, res) => getAll("users", res));
app.get("/api/users/:id", (req, res) => getById("users", req.params.id, res));

app.post("/api/users", async (req, res) => {
  const client = await pool.connect();
  try {
    await client.query("BEGIN");
    const sanitizedData = filterData("users", req.body);

    // Hash password if provided
    if (sanitizedData.password_hash) {
      const saltRounds = 10;
      sanitizedData.password_hash = await bcrypt.hash(
        sanitizedData.password_hash,
        saltRounds,
      );
    }

    const keys = Object.keys(sanitizedData).join(", ");
    const placeholders = Object.keys(sanitizedData)
      .map((_, i) => `$${i + 1}`)
      .join(", ");
    const query = `INSERT INTO users (${keys}) VALUES (${placeholders}) RETURNING *`;
    const result = await client.query(query, Object.values(sanitizedData));
    await client.query("COMMIT");
    res.status(201).json(result.rows[0]);
  } catch (err) {
    await client.query("ROLLBACK");
    console.error(`Error creating user:`, err.message);
    res.status(500).json({ error: err.message });
  } finally {
    client.release();
  }
});

app.put("/api/users/:id", async (req, res) => {
  try {
    // نمنع تحديث كلمة المرور إذا كانت فارغة
    const sanitizedData = filterData("users", req.body);

    if (sanitizedData.password_hash) {
      const saltRounds = 10;
      sanitizedData.password_hash = await bcrypt.hash(
        sanitizedData.password_hash,
        saltRounds,
      );
    }

    if (Object.keys(sanitizedData).length === 0) {
      return getById("users", req.params.id, res);
    }

    const setClause = Object.keys(sanitizedData)
      .map((key, i) => `${key} = $${i + 1}`)
      .join(", ");
    const values = [...Object.values(sanitizedData), req.params.id];
    const query = `UPDATE users SET ${setClause}, updated_at = CURRENT_TIMESTAMP WHERE id = $${values.length} RETURNING *`;
    const result = await pool.query(query, values);

    if (result.rows.length === 0)
      return res.status(404).json({ error: "Not found" });

    res.json(result.rows[0]);
  } catch (err) {
    console.error(`Error updating user:`, err.message);
    res.status(500).json({ error: err.message });
  }
});
app.delete("/api/users/:id", (req, res) => remove("users", req.params.id, res));

// Routes for Students
app.get("/api/students", (req, res) => getAll("students", res));
app.get("/api/students/:id", (req, res) =>
  getById("students", req.params.id, res),
);

app.post("/api/students", async (req, res) => {
  const client = await pool.connect();
  try {
    await client.query("BEGIN");
    const sanitizedData = filterData("students", req.body);

    // 1. إنشاء الطالب
    const keys = Object.keys(sanitizedData).join(", ");
    const placeholders = Object.keys(sanitizedData)
      .map((_, i) => `$${i + 1}`)
      .join(", ");
    const studentQuery = `INSERT INTO students (${keys}) VALUES (${placeholders}) RETURNING *`;
    const studentResult = await client.query(
      studentQuery,
      Object.values(sanitizedData),
    );
    const student = studentResult.rows[0];

    // 2. ربط المصروفات الإلزامية تلقائياً
    const assignFeesQuery = `
      INSERT INTO student_fees (student_id, expense_item_id, amount_due, status)
      SELECT $1, id, amount, 'pending' FROM expense_items
      WHERE is_mandatory = true 
      AND (department_id IS NULL OR department_id = $2)
      AND (class_year IS NULL OR class_year = '' OR class_year = 'كل الفرق' OR class_year = $3)
    `;
    await client.query(assignFeesQuery, [
      student.id,
      student.department_id,
      student.class_year,
    ]);

    await client.query("COMMIT");
    res.status(201).json(student);
  } catch (err) {
    console.error("Error in POST /api/students transaction:", err.message);
    await client.query("ROLLBACK");
    res.status(500).json({ error: err.message });
  } finally {
    client.release();
  }
});

app.put("/api/students/:id", async (req, res) => {
  const client = await pool.connect();
  try {
    await client.query("BEGIN");

    // Branch restriction check
    if (req.user && req.user.role !== "admin" && req.user.branch_id) {
      const student = await client.query(
        "SELECT branch_id FROM students WHERE id = $1",
        [req.params.id],
      );
      if (student.rows[0] && student.rows[0].branch_id !== req.user.branch_id) {
        throw new Error("Access denied: Student not in your branch");
      }
    }

    const sanitizedData = filterData("students", req.body);

    const setClause = Object.keys(sanitizedData)
      .map((key, i) => `${key} = $${i + 1}`)
      .join(", ");
    const query = `UPDATE students SET ${setClause}, updated_at = CURRENT_TIMESTAMP WHERE id = $${Object.keys(sanitizedData).length + 1} RETURNING *`;
    const values = [...Object.values(sanitizedData), req.params.id];

    const result = await client.query(query, values);

    if (result.rows.length === 0) {
      throw new Error("Student not found");
    }

    await client.query("COMMIT");
    res.json(result.rows[0]);
  } catch (err) {
    await client.query("ROLLBACK");
    console.error(`Student update error [ID:${req.params.id}]:`, err.message);
    res.status(400).json({ error: err.message });
  } finally {
    client.release();
  }
});
app.delete("/api/students/:id", (req, res) =>
  remove("students", req.params.id, res),
);

// Routes for Departments
app.get("/api/departments", async (req, res) => {
  try {
    const result = await pool.query(
      `SELECT d.*, 
              COALESCE(json_agg(db.branch_id ORDER BY db.branch_id) FILTER (WHERE db.branch_id IS NOT NULL), '[]') AS branch_ids,
              COALESCE(json_agg(b.name ORDER BY db.branch_id) FILTER (WHERE b.name IS NOT NULL), '[]') AS branch_names
       FROM departments d
       LEFT JOIN department_branches db ON d.id = db.department_id
       LEFT JOIN branches b ON db.branch_id = b.id
       GROUP BY d.id
       ORDER BY d.name`,
    );
    res.json(result.rows);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.get("/api/departments/:id", async (req, res) => {
  try {
    const result = await pool.query(
      `SELECT d.*, 
              COALESCE(json_agg(db.branch_id ORDER BY db.branch_id) FILTER (WHERE db.branch_id IS NOT NULL), '[]') AS branch_ids,
              COALESCE(json_agg(b.name ORDER BY db.branch_id) FILTER (WHERE b.name IS NOT NULL), '[]') AS branch_names
       FROM departments d
       LEFT JOIN department_branches db ON d.id = db.department_id
       LEFT JOIN branches b ON db.branch_id = b.id
       WHERE d.id = $1
       GROUP BY d.id`,
      [req.params.id],
    );
    if (result.rows.length === 0)
      return res.status(404).json({ error: "Not found" });
    res.json(result.rows[0]);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.post("/api/departments", async (req, res) => {
  const { branch_ids = [], ...payload } = req.body;
  const branchIds = Array.isArray(branch_ids)
    ? branch_ids.filter(Boolean)
    : branch_ids
      ? [branch_ids]
      : [];
  const primaryBranch = branchIds.length ? branchIds[0] : null;
  const client = await pool.connect();
  try {
    await client.query("BEGIN");
    const sanitizedData = filterData("departments", payload);
    sanitizedData.branch_id = primaryBranch;

    const keys = Object.keys(sanitizedData).join(", ");
    const placeholders = Object.keys(sanitizedData)
      .map((_, i) => `$${i + 1}`)
      .join(", ");
    const query = `INSERT INTO departments (${keys}) VALUES (${placeholders}) RETURNING *`;
    const result = await client.query(query, Object.values(sanitizedData));
    const department = result.rows[0];

    if (branchIds.length) {
      const mappings = branchIds
        .map((_, index) => `($1, $${index + 2})`)
        .join(", ");
      await client.query(
        `INSERT INTO department_branches (department_id, branch_id) VALUES ${mappings}`,
        [department.id, ...branchIds],
      );
    }

    await client.query("COMMIT");
    res.status(201).json(department);
  } catch (err) {
    await client.query("ROLLBACK");
    console.error("Error creating department:", err.message);
    res.status(500).json({ error: err.message });
  } finally {
    client.release();
  }
});

app.put("/api/departments/:id", async (req, res) => {
  const { branch_ids = [], ...payload } = req.body;
  const branchIds = Array.isArray(branch_ids)
    ? branch_ids.filter(Boolean)
    : branch_ids
      ? [branch_ids]
      : [];
  const primaryBranch = branchIds.length ? branchIds[0] : null;
  const client = await pool.connect();
  try {
    await client.query("BEGIN");
    const sanitizedData = filterData("departments", payload);
    sanitizedData.branch_id = primaryBranch;

    const setClause = Object.keys(sanitizedData)
      .map((key, i) => `${key} = $${i + 1}`)
      .join(", ");
    const values = [...Object.values(sanitizedData), req.params.id];
    await client.query(
      `UPDATE departments SET ${setClause}, updated_at = CURRENT_TIMESTAMP WHERE id = $${values.length}`,
      values,
    );

    await client.query(
      `DELETE FROM department_branches WHERE department_id = $1`,
      [req.params.id],
    );

    if (branchIds.length) {
      const mappings = branchIds
        .map((_, index) => `($1, $${index + 2})`)
        .join(", ");
      await client.query(
        `INSERT INTO department_branches (department_id, branch_id) VALUES ${mappings}`,
        [req.params.id, ...branchIds],
      );
    }

    await client.query("COMMIT");
    const updated = await pool.query(
      `SELECT d.*, 
              COALESCE(json_agg(db.branch_id ORDER BY db.branch_id) FILTER (WHERE db.branch_id IS NOT NULL), '[]') AS branch_ids,
              COALESCE(json_agg(b.name ORDER BY db.branch_id) FILTER (WHERE b.name IS NOT NULL), '[]') AS branch_names
       FROM departments d
       LEFT JOIN department_branches db ON d.id = db.department_id
       LEFT JOIN branches b ON db.branch_id = b.id
       WHERE d.id = $1
       GROUP BY d.id`,
      [req.params.id],
    );
    res.json(updated.rows[0]);
  } catch (err) {
    await client.query("ROLLBACK");
    console.error("Error updating department:", err.message);
    res.status(500).json({ error: err.message });
  } finally {
    client.release();
  }
});

app.delete("/api/departments/:id", (req, res) =>
  remove("departments", req.params.id, res),
);

