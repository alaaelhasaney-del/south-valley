{
  "name": "academy-management-system",
  "version": "1.0.0",
  "description": "Professional Academy Management System with Multi-branch and RBAC",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:photos": "node -r dotenv/config scripts/migrate-photos-to-storage.js",
    "test:images": "node tests/image-management.test.js",
    "db:migrate": "psql $DATABASE_URL < migrations/001-add-image-url-column.sql",
    "vercel-build": "echo 'No build needed for this project'"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.15.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "form-data": "^4.0.0",
    "framer-motion": "^12.38.0",
    "helmet": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "qrcode.react": "^4.2.0",
    "react-router-dom": "^7.14.1",
    "react-to-print": "^3.3.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "keywords": [
    "academy",
    "management",
    "node",
    "express",
    "postgres",
    "supabase"
  ],
  "author": "BLACKBOXAI",
  "license": "MIT",
  "build": {
    "appId": "com.suothvalley.academy",
    "productName": "South Valley Academy",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "package.json"
    ]
  }
}
